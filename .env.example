# Hyperliquid Smart-Wallet Observer defaults.
# Safe by default: read/paper only, no mainnet execution, no testnet execution.
HL_ENV=paper
HL_ENABLE_MAINNET_EXECUTION=false
HL_ENABLE_TESTNET_EXECUTION=false
HL_TESTNET_PRIVATE_KEY=
HL_DATABASE_URL=sqlite:///./logs/hl_observer.sqlite3
HL_LOG_LEVEL=INFO
HL_INFO_TIMEOUT_SECONDS=10
HL_REQUIRE_TESTNET_SCHEDULE_CANCEL=true
