# Hyperliquid Smart-Wallet Observer defaults.
# Safe by default: read/paper only, no mainnet execution, no testnet execution.
HL_ENV=paper
HL_ENABLE_MAINNET_EXECUTION=false
HL_ENABLE_TESTNET_EXECUTION=false
HL_TESTNET_PRIVATE_KEY=
HL_DATABASE_URL=sqlite:///./data/hl_observer.sqlite3
HL_LOG_LEVEL=INFO
HL_INFO_TIMEOUT_SECONDS=10
HL_REQUIRE_TESTNET_SCHEDULE_CANCEL=true

# HyperSmart Observer Sprint 1 defaults.
# No private key is required for research or paper trading.
HYPERSMART_MODE=RESEARCH_ONLY
HYPERSMART_DATABASE_PATH=data/hypersmart_observer.sqlite3
HYPERSMART_LOG_LEVEL=INFO
HYPERSMART_ENABLE_EXECUTION=false
HYPERSMART_ENABLE_TESTNET_EXECUTION=false
HYPERSMART_CONFIRM_TESTNET_ONLY=false
HYPERSMART_ALLOW_MAINNET=false
HYPERSMART_HYPERLIQUID_INFO_BASE_URL=https://api.hyperliquid-testnet.xyz
HYPERSMART_HYPERLIQUID_WS_BASE_URL=wss://api.hyperliquid-testnet.xyz/ws
HYPERSMART_HTTP_TIMEOUT_SECONDS=15
HYPERSMART_HTTP_MAX_RETRIES=2
HYPERSMART_INFO_PAGE_LIMIT=500
HYPERSMART_INFO_TIME_RANGE_PAGE_LIMIT=500
HYPERSMART_INFO_MAX_PAGES_PER_WALLET=5
HYPERSMART_MAX_PAGES_PER_WALLET=5
HYPERSMART_MAX_FILLS_PER_RUN=10000
HYPERSMART_USER_FILLS_RECENT_LIMIT=2000
HYPERSMART_USER_FILLS_BY_TIME_MAX_RECENT=10000
HYPERSMART_REST_WEIGHT_LIMIT_PER_MINUTE=1200
HYPERSMART_INFO_WEIGHT_EXTRA_ITEM_BUCKET_SIZE=20
HYPERSMART_INFO_MIN_REQUEST_INTERVAL_MS=250
HYPERSMART_ENABLE_NETWORK_READS=false
HYPERSMART_MIN_FILLS_TO_SCORE=30
HYPERSMART_MIN_HISTORY_DAYS_TO_SCORE=7
HYPERSMART_MIN_CLOSED_PNL_POINTS=10
HYPERSMART_SCORE_REQUIRE_NET_PNL=true
HYPERSMART_SCORE_MAX_LOOKBACK_DAYS=90
HYPERSMART_SCORE_RECENCY_HALF_LIFE_DAYS=14
HYPERSMART_SCORE_MIN_CONFIDENCE=0.60
HYPERSMART_SCORE_STORE_REJECTED=true
HYPERSMART_ENABLE_PAPER_TRADING=true
HYPERSMART_PAPER_STARTING_EQUITY=10000.0
HYPERSMART_PAPER_MAX_POSITION_NOTIONAL=100.0
HYPERSMART_PAPER_MAX_OPEN_TRADES=3
HYPERSMART_PAPER_FEE_RATE_BPS=5
HYPERSMART_PAPER_SPREAD_BPS=2
HYPERSMART_PAPER_SLIPPAGE_BPS=5
HYPERSMART_PAPER_LATENCY_MS=500
HYPERSMART_PAPER_MIN_WALLET_CONFIDENCE=0.60
HYPERSMART_PAPER_MIN_SAMPLE_QUALITY=0.60
HYPERSMART_PAPER_MAX_DRAWDOWN_ALLOWED=0.25
HYPERSMART_PAPER_REQUIRE_SCORED_WALLET=true
HYPERSMART_PAPER_STORE_REFUSALS=true
HYPERSMART_RUNTIME_ROOT=.
HYPERSMART_DASHBOARD_DIR=data/dashboard
HYPERSMART_REPORTS_DIR=data/reports
HYPERSMART_EXPLORER_OBSERVER_ENABLED=false
HYPERSMART_WS_MONITOR_ENABLED=false
HYPERSMART_WS_MAX_CONNECTIONS=10
HYPERSMART_WS_MAX_NEW_CONNECTIONS_PER_MIN=30
HYPERSMART_WS_MAX_USER_SUBSCRIPTIONS=10
HYPERSMART_WS_MAX_UNIQUE_USERS=10
HYPERSMART_WS_MAX_SUBSCRIPTIONS=1000
HYPERSMART_EXPLORER_WEIGHT=40
HYPERSMART_ARCHIVE_OUTPUT_DIR=data/archives
HYPERSMART_COPY_POLL_INTERVAL_SECONDS=300
HYPERSMART_COPY_MIN_EDGE_REQUIRED_BPS=8
HYPERSMART_COPY_MAX_SIGNAL_AGE_MS=300000
HYPERSMART_COPY_MAX_DEGRADATION_BPS=40
HYPERSMART_COPY_LEADERBOARD_TARGET_COUNT=5
HYPERSMART_COPY_MAX_LEADERS_PER_RUN=3
HYPERSMART_COPY_MIN_HISTORY_DAYS=7
HYPERSMART_COPY_MIN_CLOSED_PNL_POINTS=10
